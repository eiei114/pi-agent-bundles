{
  "name": "pi-agent-bundles",
  "version": "0.1.0",
  "private": true,
  "description": "Git-distributed Pi agent bundles for Multica and project-specific runtime defaults.",
  "type": "module",
  "license": "MIT",
  "author": "Keisu",
  "keywords": [
    "pi-package",
    "pi",
    "agent-bundle",
    "multica",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-agent-bundles.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-agent-bundles/issues"
  },
  "homepage": "https://github.com/eiei114/pi-agent-bundles#readme",
  "files": [
    "shared/",
    "bundles/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test && npm run pack:check",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./shared/extensions",
      "./bundles/*/extensions",
      "./node_modules/pi-model-fallback/extensions"
    ],
    "skills": [
      "./bundles/*/skills"
    ]
  },
  "dependencies": {
    "pi-model-fallback": "^0.1.0"
  },
  "bundledDependencies": [
    "pi-model-fallback"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typebox": "latest",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3"
  }
}
