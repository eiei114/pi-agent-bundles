{
  "name": "pi-agent-bundles",
  "version": "0.5.0",
  "private": true,
  "description": "Git-distributed Pi agent bundles for Multica and project-specific runtime defaults.",
  "type": "module",
  "license": "MIT",
  "author": "Keisu",
  "keywords": [
    "pi-package",
    "pi",
    "agent-bundle",
    "multica",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-agent-bundles.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-agent-bundles/issues"
  },
  "homepage": "https://github.com/eiei114/pi-agent-bundles#readme",
  "files": [
    "shared/",
    "bundles/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./shared/extensions",
      "./bundles/*/extensions",
      "./node_modules/pi-model-fallback/extensions",
      "./node_modules/pi-fff/index.ts",
      "./node_modules/pi-fff-non-ascii-guard/extensions",
      "./node_modules/pi-smart-fetch/dist/index.js",
      "./node_modules/pi-multica-spine/extensions",
      "./node_modules/context-mode/build/adapters/pi/extension.js",
      "./shared/post-context-mode/extensions",
      "./node_modules/@howaboua/pi-codex-conversion/src/index.ts",
      "./node_modules/@offbynan/pi-cursor-provider/index.ts"
    ],
    "skills": [
      "./bundles/*/skills"
    ]
  },
  "dependencies": {
    "pi-model-fallback": "github:eiei114/pi-model-fallback#v0.3.0",
    "pi-fff": "^0.1.12",
    "pi-fff-non-ascii-guard": "0.1.6",
    "pi-smart-fetch": "^0.3.12",
    "pi-multica-spine": "^0.1.2",
    "context-mode": "^1.0.169",
    "@howaboua/pi-codex-conversion": "^2.1.6",
    "@offbynan/pi-cursor-provider": "^0.5.3"
  },
  "bundledDependencies": [
    "@howaboua/pi-codex-conversion",
    "@offbynan/pi-cursor-provider",
    "context-mode",
    "pi-fff",
    "pi-fff-non-ascii-guard",
    "pi-multica-spine",
    "pi-smart-fetch"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "typebox": "latest",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  }
}
