{
  "name": "pi-agent-bundles",
  "version": "0.6.8",
  "private": true,
  "description": "Git-distributed Pi agent bundles for Multica and project-specific runtime defaults.",
  "type": "module",
  "license": "MIT",
  "author": "Keisu",
  "keywords": [
    "pi-package",
    "pi",
    "agent-bundle",
    "multica",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eiei114/pi-agent-bundles.git"
  },
  "bugs": {
    "url": "https://github.com/eiei114/pi-agent-bundles/issues"
  },
  "homepage": "https://github.com/eiei114/pi-agent-bundles#readme",
  "files": [
    "shared/",
    "bundles/",
    "docs/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run typecheck && npm test",
    "pack:check": "npm pack --dry-run"
  },
  "pi": {
    "extensions": [
      "./shared/extensions/agent-bundle-loader.ts"
    ],
    "skills": []
  },
  "dependencies": {
    "@howaboua/pi-codex-conversion": "^2.1.6",
    "@offbynan/pi-cursor-provider": "^0.5.3",
    "context-mode": "^1.0.169",
    "pi-fff": "^0.1.12",
    "pi-fff-non-ascii-guard": "^0.1.9",
    "pi-mcp-adapter": "^2.11.0",
    "pi-model-fallback": "^0.3.3",
    "pi-multica-spine": "^0.1.4",
    "pi-smart-fetch": "^0.3.12"
  },
  "bundledDependencies": [
    "@howaboua/pi-codex-conversion",
    "@offbynan/pi-cursor-provider",
    "context-mode",
    "pi-fff",
    "pi-fff-non-ascii-guard",
    "pi-mcp-adapter",
    "pi-multica-spine",
    "pi-smart-fetch"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "latest",
    "@earendil-works/pi-coding-agent": "latest",
    "@earendil-works/pi-tui": "latest",
    "@types/node": "^26.0.0",
    "typebox": "latest",
    "typescript": "^6.0.3"
  },
  "bundleDependencies": [
    "@howaboua/pi-codex-conversion",
    "@offbynan/pi-cursor-provider",
    "context-mode",
    "pi-fff",
    "pi-fff-non-ascii-guard",
    "pi-mcp-adapter",
    "pi-multica-spine",
    "pi-smart-fetch"
  ]
}
